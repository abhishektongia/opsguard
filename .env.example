# Database
DATABASE_URL=postgresql://user:password@localhost:5432/opsguard

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# OAuth Providers
GITHUB_ID=your-github-id
GITHUB_SECRET=your-github-secret
GOOGLE_ID=your-google-id
GOOGLE_SECRET=your-google-secret
MICROSOFT_ID=your-microsoft-id
MICROSOFT_SECRET=your-microsoft-secret

# Redis
REDIS_URL=redis://localhost:6379

# Email
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@opsguard.com
SENDGRID_WEBHOOK_SECRET=your-webhook-secret

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your-public-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=opsguard-bucket
AWS_REGION=us-east-1

# Socket.IO
SOCKET_IO_PORT=3001

# Logging
LOG_LEVEL=info

# App
NODE_ENV=development
